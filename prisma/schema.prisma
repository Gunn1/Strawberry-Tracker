// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN // full access, including managing users
  STAFF // till, status, sales — everything except user management
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  role          Role            @default(STAFF)
  active        Boolean         @default(false) // may sign in (set when invited by an admin)
  accounts      Account[]
  sessions      Session[]
  sales Sale[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}
 
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}
 
// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([userId, credentialID])
}

enum SaleMode {
  QUART      // strawberries, by the quart
  ASPARAGUS  // by the pound
  RHUBARB    // by the pound
}

// Singleton row of stand prices + today's open status. id is always "default".
model StandSettings {
  id             String @id @default("default")
  quartCents     Int    @default(500) // strawberries, per quart
  asparagusCents Int    @default(350) // per pound
  rhubarbCents   Int    @default(300) // per pound

  // Customer-facing status is COMPUTED from the schedule below plus an optional
  // same-day override set by staff at /admin (override wins for that day).
  seasonActive   Boolean @default(false)         // is U-pick season on?
  openMin        Int     @default(420)           // opens 7:00 a.m. (minutes from midnight, farm-local)
  closeMin       Int     @default(720)           // closes at noon
  finishByMin    Int     @default(750)           // finish picking by 12:30 p.m.
  openDays       String  @default("1,2,3,4,5,6") // weekday numbers open (0=Sun … 6=Sat)
  overrideStatus String  @default("")            // "" = follow schedule; else open|closed|pickedout
  overrideDate   String  @default("")            // YYYY-MM-DD (farm-local) the override applies to
  statusNote     String  @default("")            // note shown with the override

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  mode           SaleMode
  quantity       Int      // # of quarts (strawberries) or pounds (asparagus / rhubarb)
  unitPriceCents Int      // price per unit AT TIME OF SALE
  totalCents     Int      // quantity * unitPriceCents
  tenderedCents  Int      // cash received
  changeCents    Int      // tenderedCents - totalCents

  cashierId      String?
  cashier        User?    @relation(fields: [cashierId], references: [id])

  @@index([createdAt])
  @@index([cashierId])
}

// A bookable U-pick window on a given day. Times are wall-clock minutes from
// midnight (no timezone math) so an "8:00–9:30 AM" slot always reads the same.
model Slot {
  id       String   @id @default(cuid())
  date     DateTime @db.Date // the picking day
  startMin Int               // window start, minutes from midnight (480 = 8:00 AM)
  endMin   Int               // window end, minutes from midnight
  capacity Int      @default(20) // max pickers allowed in the window

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, startMin])
  @@index([date])
}

model Reservation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  slotId    String
  slot      Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  name      String
  email     String
  partySize Int // number of pickers in this booking

  @@index([slotId])
}

// Folks who want a heads-up when strawberry season opens.
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

