    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
